/*
 * SPDX-License-Identifier: MIT
 *
 * "Glue" shield: bridges the corne shield's OLED I2C footprint to a
 * Nice!View SPI bus. Used in the shield combination:
 *
 *     corne_left  nice_view_adapter  corne_nv_glue  nice_view
 *     corne_right nice_view_adapter  corne_nv_glue  nice_view
 *
 * The order matters: corne_nv_glue must come BEFORE nice_view so this
 * overlay is parsed first and defines &nice_view_spi (which nice_view's
 * own overlay then references).
 *
 * Upstream nice_view_adapter.overlay is empty; per its README the user
 * must provide the SPI bus.
 *
 * nice!nano's default spi1_default pinctrl routes SCK to P1.13 and
 * MOSI to P0.10 — those pins are NOT on the Corne OLED footprint.
 * The OLED footprint uses P0.17 (SDA) and P0.20 (SCL), which we
 * re-purpose as MOSI and SCK for the SHARP LCD. CS is bodged to D1
 * per nice_view_adapter README's documented convention.
 */

#include <zephyr/dt-bindings/pinctrl/nrf-pinctrl.h>

&pinctrl {
    nice_view_spi_default: nice_view_spi_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 20)>,    /* P0.20 = OLED SCL pad */
                    <NRF_PSEL(SPIM_MOSI, 0, 17)>;   /* P0.17 = OLED SDA pad */
        };
    };

    nice_view_spi_sleep: nice_view_spi_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 20)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 17)>;
            low-power-enable;
        };
    };
};

&pro_micro_i2c {
    status = "disabled";
};

nice_view_spi: &pro_micro_spi {
    status = "okay";
    cs-gpios = <&pro_micro 1 GPIO_ACTIVE_HIGH>;
    pinctrl-0 = <&nice_view_spi_default>;
    pinctrl-1 = <&nice_view_spi_sleep>;
    pinctrl-names = "default", "sleep";
};
